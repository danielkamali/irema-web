rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Safe isAdmin — only checks existence, no nested get() call
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // Active admin — used for destructive writes only
    function isActiveAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.isActive == true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isActiveAdmin();
    }

    match /companies/{companyId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isActiveAdmin() || (
        isSignedIn() &&
        resource.data.adminUserId == request.auth.uid &&
        request.resource.data.adminUserId == resource.data.adminUserId
      ) || (
        // Non-sensitive counter updates: any visitor may increment view counts,
        // and any reviewer needs to refresh the rating aggregate after posting.
        // Allowed fields are ONLY these; everything else still requires admin/owner.
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['totalReviews', 'averageRating', 'viewCount'])
      ) || (
        // Slug backfill: any signed-in user may set the slug when it is
        // currently missing. This lets CompanyPage canonicalise legacy
        // /company/:id URLs to /business/<slug> even for non-owners, so
        // visitors no longer see the bare company ID flash during refresh.
        isSignedIn() &&
        (!('slug' in resource.data) || resource.data.slug == null || resource.data.slug == '') &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['slug']) &&
        request.resource.data.slug is string &&
        request.resource.data.slug.size() > 0
      );
      allow delete: if isActiveAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      // Pin the reviewer's userId to the auth uid so a signed-in user can't
      // forge a review attributed to someone else.
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        // Author can edit their own review
        request.auth.uid == resource.data.userId ||
        // Company owner can add replies to reviews of their own business
        (request.resource.data.replies != null &&
          exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
          get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.adminUserId == request.auth.uid)
      );
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.userId || isAdmin()
      );
    }

    match /review_reactions/{docId} {
      allow read: if true;
      // Pin userId on create so users can't attribute reactions to someone
      // else.
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      // On update, the existing doc must already be the user's AND they
      // must not flip the userId to someone else's uid.
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /notifications/{notifId} {
      // Recipients (targetUserId) and admins can read. Company-scoped
      // notifications remain visible to the company owner via the
      // adminUserId lookup.
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.targetUserId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        (resource.data.companyId != null &&
          exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
          get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.adminUserId == request.auth.uid)
      );
      // Any signed-in user may create a notification (e.g. reviewer
      // notifies the business owner), but they cannot set themselves as
      // the recipient of an arbitrary admin-only notification.
      allow create: if isSignedIn();
      // Recipients may flip the "read" flag on their own notifications,
      // and admins may fully update. Nobody else can tamper with the
      // message body.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          (resource.data.targetUserId == request.auth.uid ||
           resource.data.userId == request.auth.uid) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['read', 'readAt'])
        )
      );
      // Only the recipient or an admin may delete.
      allow delete: if isSignedIn() && (
        isAdmin() ||
        resource.data.targetUserId == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
    }

    match /claims/{claimId} {
      // Claim submissions contain personal contact info — only the
      // submitter and admins may read them. The existing client writes
      // the submitter's uid into `claimantUserId`; newer payloads may
      // use `userId` so we accept either.
      allow read: if isAdmin() || (
        isSignedIn() && (
          resource.data.claimantUserId == request.auth.uid ||
          resource.data.userId == request.auth.uid
        )
      );
      allow create: if isSignedIn() && (
        request.resource.data.claimantUserId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
      allow update: if isActiveAdmin();
      allow delete: if isActiveAdmin();
    }

    match /admin_users/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if isActiveAdmin();
    }

    match /admin_roles/{roleId} {
      allow read: if isAdmin();
      allow write: if isActiveAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /admin_activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /security_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /qr_scans/{scanId} {
      // Scan logs are admin-only; keeping them signed-in-readable would
      // leak user/business tracking data to any authenticated user.
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    match /admin_2fa/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /admin_settings/{settingId} {
      // Translation override docs (translations_en, _fr, _rw, _sw) are read
      // by every visitor at app boot so admin-edited copy renders for everyone.
      // All OTHER admin_settings docs stay admin-read-only.
      allow read: if isAdmin() || settingId.matches('translations_.*');
      allow write: if isActiveAdmin();
    }

    match /company_stories/{storyId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.addedBy || isAdmin()
      );
      allow delete: if isActiveAdmin() || (
        isSignedIn() && request.auth.uid == resource.data.addedBy
      );
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isActiveAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      // New products must belong to a company the creator owns.
      allow create: if isSignedIn() && (
        isAdmin() ||
        (request.resource.data.companyId != null &&
          exists(/databases/$(database)/documents/companies/$(request.resource.data.companyId)) &&
          get(/databases/$(database)/documents/companies/$(request.resource.data.companyId)).data.adminUserId == request.auth.uid)
      );
      // Only the company owner (or an admin) may edit or delete — the
      // previous `ownerId` field was never actually set on product docs,
      // so authorise via the linked company's adminUserId instead.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == resource.data.ownerId) ||
        (resource.data.companyId != null &&
          exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
          get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.adminUserId == request.auth.uid)
      );
      allow delete: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == resource.data.ownerId) ||
        (resource.data.companyId != null &&
          exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
          get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.adminUserId == request.auth.uid)
      );
    }

    match /subscriptions/{subId} {
      // Admins see all; company owners can read their own subscription.
      allow read: if isAdmin() || (
        isSignedIn() &&
        resource.data.companyId != null &&
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.adminUserId == request.auth.uid
      );
      // Creating a subscription requires ownership of the linked company
      // (or admin). Prevents a signed-in user from spinning up a billing
      // record attached to someone else's business.
      allow create: if isSignedIn() && (
        isAdmin() ||
        (request.resource.data.companyId != null &&
          exists(/databases/$(database)/documents/companies/$(request.resource.data.companyId)) &&
          get(/databases/$(database)/documents/companies/$(request.resource.data.companyId)).data.adminUserId == request.auth.uid)
      );
      // Same ownership rule on update — previously ANY signed-in user
      // could flip plan/locked/status on ANY subscription.
      allow update: if isActiveAdmin() || (
        isSignedIn() &&
        resource.data.companyId != null &&
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.adminUserId == request.auth.uid
      );
      allow delete: if isActiveAdmin();
    }

    match /enterprise_enquiries/{enquiryId} {
      // Enterprise enquiries expose contact info + business context —
      // lock read access to admins and the original submitter.
      allow read: if isAdmin() || (
        isSignedIn() && (
          resource.data.userId == request.auth.uid ||
          (resource.data.companyId != null &&
            exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
            get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.adminUserId == request.auth.uid)
        )
      );
      allow create: if isSignedIn();
      allow update: if isActiveAdmin();
      allow delete: if isActiveAdmin();
    }

    match /analytics_metrics/{companyId} {
      // Latest analytics snapshot - readable by company owner or admin
      allow read: if isSignedIn() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/companies/$(companyId)) &&
          get(/databases/$(database)/documents/companies/$(companyId)).data().adminUserId == request.auth.uid)
      );
      allow write: if isAdmin();  // Cloud Functions only

      // Daily snapshots
      match /daily/{docId} {
        allow read: if isSignedIn() && (
          isAdmin() ||
          (exists(/databases/$(database)/documents/companies/$(companyId)) &&
            get(/databases/$(database)/documents/companies/$(companyId)).data().adminUserId == request.auth.uid)
        );
        allow write: if isAdmin();  // Cloud Functions only
      }
    }

    match /blogs/{blogId} {
      allow read: if true;  // Public read for published blogs
      allow create: if isActiveAdmin();
      allow update: if isActiveAdmin();
      allow delete: if isActiveAdmin();
    }

    match /newsletter_subscribers/{docId} {
      allow read: if isAdmin();  // Admins see all subscribers
      allow create: if true;      // Anyone can subscribe (via NewsletterPage)
      allow update: if isAdmin() || request.auth.uid == docId;  // Self-unsubscribe
      allow delete: if isAdmin();
    }

    match /blog_views/{docId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /blog_likes/{docId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid || isAdmin();
    }

    match /blog_comments/{docId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid || isAdmin();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid || isAdmin();
    }

    match /support_chats/{chatId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /rate_limits/{docId} {
      allow read: if isSignedIn();
      allow write: if false;  // Cloud Function only
    }

    match /newsletter_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;  // Cloud Function only
    }
  }
}
