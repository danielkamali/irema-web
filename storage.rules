rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Business logos — only the company owner may write
    match /logos/{companyId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/companies/$(companyId)).data.adminUserId
           == request.auth.uid;
    }

    // Business gallery photos — only the company owner may write
    match /business-photos/{companyId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/companies/$(companyId)).data.adminUserId
           == request.auth.uid;
    }

    // Review photos — only the review author may write; max 10 MB per file
    match /review-photos/{reviewId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size <= 10 * 1024 * 1024
        && firestore.get(/databases/(default)/documents/reviews/$(reviewId)).data.userId
           == request.auth.uid;
    }

    // Profile images — only the account owner may write
    match /profiles/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny all other writes by default
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
